# OpenRouter API Key — get yours at https://openrouter.ai
# Add this in Netlify Dashboard > Site Settings > Environment Variables
# NEVER prefix with VITE_ — must stay server-side only
OPENROUTER_API_KEY=sk-or-your-key-here

# Access Control Mode: "code" (default) or "identity"
# "code"     — users enter a 6-digit code to access the app
# "identity" — users must be invited via Netlify Identity magic link
ACCESS_MODE=code

# 6-digit access code (only used when ACCESS_MODE=code)
ACCESS_CODE=123456

# SHA-256 hash of your ACCESS_CODE (hex string, lowercase)
# Generate with: echo -n "123456" | sha256sum
# This is safe to expose in the Vite bundle (VITE_ prefix)
VITE_ACCESS_CODE_HASH=8d969eef6ecad3c29a3a629280e686cf0c3f5d5a86aff3ca12020c923adc6c92

# Access mode exposed to the frontend
VITE_ACCESS_MODE=code

# Your Netlify site URL (used in OpenRouter referer header)
VITE_SITE_URL=https://your-site.netlify.app
